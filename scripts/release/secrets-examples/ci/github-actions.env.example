# ===== GitHub Actions CI シークレット =====
# gh secret set で GitHub Actions に同期される。
# staging Vercel には CI_E2E_AUTH_SECRET / CI_E2E_AUTH_ENABLED / PLAYWRIGHT_BASE_URL が overlay される。

# [Required] E2E テスト用認証シークレット（32文字以上推奨）
CI_E2E_AUTH_SECRET=
# [Required] E2E テスト Auth 有効化（1 = 有効、0 = 無効）
CI_E2E_AUTH_ENABLED=1
# [Required] Playwright テスト用ベースURL
PLAYWRIGHT_BASE_URL=https://stg.shupass.jp

# [Required] CI で使う LLM API キー（AI Live テスト等）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# [Optional] CI で使う Firecrawl API キー
#FIRECRAWL_API_KEY=
