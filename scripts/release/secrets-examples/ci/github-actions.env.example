# ===== GitHub Actions CI シークレット =====
# gh secret set で GitHub Actions に同期される。
# staging Vercel には CI_E2E_AUTH_SECRET / CI_E2E_AUTH_ENABLED / PLAYWRIGHT_BASE_URL が overlay される。

# [必須] E2E テスト用認証シークレット（32文字以上推奨） [環境別]
CI_E2E_AUTH_SECRET=
# [必須] E2E テスト Auth 有効化（1 = 有効、0 = 無効） [共通可]
CI_E2E_AUTH_ENABLED=1
# [必須] Playwright テスト用ベースURL [環境別]
PLAYWRIGHT_BASE_URL=https://stg.shupass.jp

# [必須] CI で使う LLM API キー（AI Live テスト等） [共通可]
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# [任意] CI で使う Firecrawl API キー [共通可]
FIRECRAWL_API_KEY=
