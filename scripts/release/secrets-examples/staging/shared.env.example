# ===== クロスサービス共有変数（staging） =====
# Next.js (BFF) と FastAPI の両方で同じ値を設定する必要がある変数。
# shared.env に一元管理し、nextjs.env / fastapi.env には重複定義しないこと。
# sync スクリプトが merge_env_files() で shared.env → service env の順にマージする。
#
# 重要: production/shared.env とは異なる値を使うこと。
# 値の生成: openssl rand -hex 32

# [必須] BFF→FastAPI 内部通信用 JWT シークレット（32文字以上） [環境別]
INTERNAL_API_JWT_SECRET=

# [必須] X-Career-Principal ヘッダ署名用 HMAC シークレット（32文字以上） [環境別]
CAREER_PRINCIPAL_HMAC_SECRET=

# [必須] テナントキー導出用シークレット（32文字以上） [環境別]
# ChromaDB / BM25 のテナント分離に使用
TENANT_KEY_SECRET=
