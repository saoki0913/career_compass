# ===== Railway Staging 環境変数 =====
# sync スクリプトが shared.env → fastapi.env の順でマージするため、
# INTERNAL_API_JWT_SECRET / CAREER_PRINCIPAL_HMAC_SECRET / TENANT_KEY_SECRET は
# shared.env で管理し、ここには書かないこと。

# ===== sync メタキー（Railway CLI 操作に必要） =====
# [必須] Railway プロジェクトID [環境別]
RAILWAY_PROJECT_ID=
# [必須] Railway サービス名 [共通可]
RAILWAY_SERVICE_NAME=
# [必須] Railway 環境名。staging 専用 project の既定環境を使うため production 固定。 [共通可]
# アプリの論理環境は APP_ENV=staging で判定する。
RAILWAY_ENVIRONMENT_NAME=production

# ===== アプリケーション =====
# [必須] 環境名 — fail-fast バリデーションのトリガー [環境別]
# staging / production を設定すると、必須変数が欠けた場合に起動が失敗する
APP_ENV=staging

# ===== CORS =====
# [必須] 許可オリジン（JSON 配列 or カンマ区切り） [環境別]
CORS_ORIGINS=["https://stg.shupass.jp"]

# ===== LLM API キー =====
# [必須] OpenAI API キー（RAG / 検索 / 企業情報で使用） [共通可]
OPENAI_API_KEY=
# [必須] Anthropic API キー（ES 添削 / 面接 / 下書きで使用） [共通可]
ANTHROPIC_API_KEY=
# [任意] Google Gemini API キー [共通可]
GOOGLE_API_KEY=

# ===== Document AI (PDF OCR) =====
# [任意] Google Document AI プロジェクトID [共通可]
GOOGLE_DOCUMENT_AI_PROJECT_ID=
# [任意] Document AI ロケーション [共通可]
GOOGLE_DOCUMENT_AI_LOCATION=us
# [任意] Document AI プロセッサID [共通可]
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# [任意] Document AI サービスアカウント JSON [共通可]
GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_JSON=

# ===== Mistral (高精度 OCR) =====
# [任意] Mistral API キー（pixtral-large-latest による OCR） [共通可]
MISTRAL_API_KEY=

# ===== Firecrawl (選考スケジュール HTML 抽出) =====
# [任意] 本番のみ。無料枠 1,000 credits/月が staging と共有になり逼迫するため staging では無効化。
# 未設定時は HTML+LLM 直接抽出に fallback するので staging でも抽出機能は動く。使う場合は解除して値を入れる。
#FIRECRAWL_API_KEY=
#FIRECRAWL_BASE_URL=https://api.firecrawl.dev
#FIRECRAWL_TIMEOUT_SECONDS=30

# ===== Redis =====
# [必須] FastAPI SSE concurrency / cache 用 Redis URL（staging/production で同一 URL を共有可・namespace で分離） [共有可]
REDIS_URL=
# [任意] Redis 名前空間（未設定なら APP_ENV を使用し staging/production を分離・設定時は APP_ENV と一致必須） [環境別]
REDIS_NAMESPACE=staging

# ===== フロントエンド連携 =====
# [必須] フロントエンド URL（CORS 判定・リダイレクト先） [環境別]
FRONTEND_URL=https://stg.shupass.jp
# [必須] 受け付ける Host 名（JSON 配列 or カンマ区切り） [環境別]
BACKEND_TRUSTED_HOSTS=["stg-api.shupass.jp"]

# [任意] アプリケーションポート（Railway が自動注入する場合が多い） [共通可]
#PORT=8000

# ===== Sentry（staging は未導入） =====
# [任意] staging では未設定でよい。本番のみ導入推奨 [環境別]
#SENTRY_DSN=
#SENTRY_FASTAPI_DSN=
#BACKEND_SENTRY_DSN=
# [任意] [環境別]
#SENTRY_ENVIRONMENT=staging
# [任意] [共通可]
#SENTRY_TRACES_SAMPLE_RATE=0.05

# ===== LLM モデル設定 =====
# [任意] 実モデル ID（デフォルト値あり） [共通可]
#CLAUDE_SONNET_MODEL=claude-sonnet-4-6
#CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
#GPT_MODEL=gpt-5.4
#GPT_MINI_MODEL=gpt-5.4-mini
#GPT_NANO_MODEL=gpt-5.4-nano
#LOW_COST_REVIEW_MODEL=claude-haiku-4-5-20251001
#GEMINI_MODEL=gemini-3.1-pro-preview
#GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# [任意] 機能別モデル（stable alias） [共通可]
#MODEL_ES_REVIEW=claude-sonnet
#MODEL_GAKUCHIKA=claude-haiku
#MODEL_GAKUCHIKA_DRAFT=claude-sonnet
#MODEL_MOTIVATION=claude-haiku
#MODEL_MOTIVATION_DRAFT=claude-sonnet
#MODEL_INTERVIEW=claude-haiku
#MODEL_INTERVIEW_PLAN=gpt
#MODEL_INTERVIEW_FEEDBACK=claude-sonnet
#MODEL_SELECTION_SCHEDULE=gpt-mini
#MODEL_COMPANY_INFO=gpt-mini
#MODEL_RAG_QUERY_EXPANSION=gpt-mini
#MODEL_RAG_HYDE=gpt-mini
#MODEL_RAG_CLASSIFY=gpt-nano

# ===== LLM コストロギング（開発者向け） =====
# [任意] [共通可]
#LLM_USAGE_COST_LOG=false
#LLM_USAGE_COST_DEBUG_LOG=false
#LLM_COST_USD_TO_JPY_RATE=155

# ===== LLM タイムアウト =====
# [任意] [共通可]
#LLM_TIMEOUT_SECONDS=120
#RAG_TIMEOUT_SECONDS=45

# ===== RAG 埋め込み =====
# [任意] [共通可]
#OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#EMBEDDING_MAX_INPUT_CHARS=8000

# ===== RAG 検索チューニング =====
# [任意] [共通可]
#USE_HYBRID_SEARCH=false
#WEB_SEARCH_FAST_MAX_QUERIES=4

# ===== 機能フラグ =====
# [任意] [共通可]
#MOTIVATION_RAG_GROUNDING=true
#MOTIVATION_MULTIPASS_REFINEMENT=true
#MOTIVATION_SEMANTIC_CONFIRM=false
#MOTIVATION_EMBEDDING_DEDUP=false
#CONTEXTUAL_RETRIEVAL_ENABLED=false
#CONTEXTUAL_RETRIEVAL_DUAL_WRITE=false

# ===== デバッグ =====
# [任意] [共通可]
#DEBUG=false
#COMPANY_SEARCH_DEBUG=false
#WEB_SEARCH_DEBUG=false
