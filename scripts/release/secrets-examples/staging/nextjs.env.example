# ===== Vercel Staging 環境変数 =====
# sync スクリプトが shared.env → nextjs.env の順でマージするため、
# INTERNAL_API_JWT_SECRET / CAREER_PRINCIPAL_HMAC_SECRET / TENANT_KEY_SECRET は
# shared.env で管理し、ここには書かないこと。

# ===== sync メタキー（Vercel CLI 操作に必要） =====
# [Required] Vercel プロジェクトID（Vercel Dashboard → Project Settings → General）
VERCEL_PROJECT_ID=
# [Required] Vercel チームID（Vercel Dashboard → Team Settings）
VERCEL_TEAM_ID=

# ===== データベース =====
# [Required] Supabase PostgreSQL 接続URL（Pooler/6543 推奨）
# 例: postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=
# [Optional] マイグレーション用 Postgres 直通URL（5432）
# 例: postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
#DATABASE_POOL_SIZE=
#DIRECT_URL=

# ===== 認証 (Better Auth + Google OAuth) =====
# [Required] 認証シークレット（32文字以上）
BETTER_AUTH_SECRET=
# [Required] 認証エンドポイントURL
BETTER_AUTH_URL=https://stg.shupass.jp
# [Required] 信頼されたオリジン（カンマ区切り）
BETTER_AUTH_TRUSTED_ORIGINS=https://stg.shupass.jp
# [Required] Google OAuth クライアントID
GOOGLE_CLIENT_ID=
# [Required] Google OAuth シークレット
GOOGLE_CLIENT_SECRET=

# ===== Stripe 決済 =====
# [Required] Stripe シークレットキー（staging は sk_test_...）
STRIPE_SECRET_KEY=
# [Required] Stripe Webhook シークレット（whsec_...）
STRIPE_WEBHOOK_SECRET=
# [Optional] Price ID（テスト環境用）
#STRIPE_PRICE_STANDARD_MONTHLY=
#STRIPE_PRICE_STANDARD_ANNUAL=
#STRIPE_PRICE_PRO_MONTHLY=
#STRIPE_PRICE_PRO_ANNUAL=

# ===== 暗号化・セキュリティ =====
# [Required] AES-256-GCM 暗号化キー（64桁hex = 32バイト）
# 生成: openssl rand -hex 32
ENCRYPTION_KEY=
# [Required] Cron ジョブ認証トークン
CRON_SECRET=

# ===== BFF→FastAPI 接続 =====
# [Required] FastAPI バックエンドURL
FASTAPI_URL=https://stg-api.shupass.jp
# [Optional] FASTAPI_URL のフォールバック（通常は不要）
#BACKEND_URL=

# ===== Redis (Upstash) =====
# [Required on deployed AI] Upstash Redis REST URL（レートリミット、日次トークン制限に使用）
# Upstash ダッシュボード → REST API セクションからコピー
# Free plan で 1 DB 共有する場合も namespace で staging を分離
#UPSTASH_REDIS_REST_URL=https://xxxxxxx.upstash.io
#UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_NAMESPACE=stg

# ===== メール (Resend) =====
#RESEND_API_KEY=
#CONTACT_TO_EMAIL=
#CONTACT_FROM_EMAIL=

# ===== ロゴプロバイダー =====
# [Optional] Logo.dev publishable key（企業アイコンの実ロゴ取得）
#LOGO_DEV_TOKEN=
# [Optional] Logo.dev secret key（企業名から domain を解決）
#LOGO_DEV_SECRET_KEY=
# [Optional] Brandfetch Client ID（Logo.dev fallback）
#BRANDFETCH_CLIENT_ID=

# ===== Sentry =====
#SENTRY_ORG=
#SENTRY_PROJECT=
#SENTRY_AUTH_TOKEN=

# ===== CI / E2E テスト =====
# staging Vercel には ci/github-actions.env から overlay される:
#   CI_E2E_AUTH_SECRET, CI_E2E_AUTH_ENABLED, PLAYWRIGHT_BASE_URL

# ===== 機能フラグ =====
# [Optional] true で日次トークン上限チェック全体を無効化
#DISABLE_TOKEN_LIMIT=

# ===== 公開クライアント変数 =====
# [Required] アプリケーション公開URL
NEXT_PUBLIC_APP_URL=https://stg.shupass.jp
# [Optional] Google Analytics 測定ID
#NEXT_PUBLIC_GA_MEASUREMENT_ID=
# [Optional] Google Search Console 認証タグ
#NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# [Optional] Sentry DSN（クライアント側エラー収集）
#NEXT_PUBLIC_SENTRY_DSN=
# [Optional] Stripe 公開キー（staging は pk_test_...）
#NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# [Optional] Logo.dev publishable key（クライアント側使用）
#NEXT_PUBLIC_LOGO_DEV_TOKEN=
# [Optional] Brandfetch Client ID（クライアント側使用）
#NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=
