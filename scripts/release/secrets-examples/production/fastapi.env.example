# ===== Railway Production 環境変数 =====
# sync スクリプトが shared.env → fastapi.env の順でマージするため、
# INTERNAL_API_JWT_SECRET / CAREER_PRINCIPAL_HMAC_SECRET / TENANT_KEY_SECRET は
# shared.env で管理し、ここには書かないこと。

# ===== sync メタキー（Railway CLI 操作に必要） =====
# [Required] Railway プロジェクトID
RAILWAY_PROJECT_ID=
# [Required] Railway サービス名
RAILWAY_SERVICE_NAME=
# [Required] Railway 環境名。production 専用 project の既定環境。
RAILWAY_ENVIRONMENT_NAME=production

# ===== アプリケーション =====
# [Required] 環境名 — fail-fast バリデーションのトリガー
APP_ENV=production

# ===== CORS =====
# [Required] 許可オリジン
CORS_ORIGINS=["https://www.shupass.jp","https://shupass.jp"]

# ===== LLM API キー =====
# [Required] OpenAI API キー
OPENAI_API_KEY=
# [Required] Anthropic API キー
ANTHROPIC_API_KEY=
#GOOGLE_API_KEY=

# ===== Document AI (PDF OCR) =====
#GOOGLE_DOCUMENT_AI_PROJECT_ID=
#GOOGLE_DOCUMENT_AI_LOCATION=us
#GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
#GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_JSON=

# ===== Mistral (高精度 OCR) =====
#MISTRAL_API_KEY=

# ===== Firecrawl =====
#FIRECRAWL_API_KEY=
#FIRECRAWL_BASE_URL=https://api.firecrawl.dev
#FIRECRAWL_TIMEOUT_SECONDS=30

# ===== Redis =====
# [Required] FastAPI SSE concurrency / cache 用 Redis URL
REDIS_URL=
# [Required] staging / production で同じ Redis を共有する場合も名前空間は必ず分ける
REDIS_NAMESPACE=production

# ===== フロントエンド連携 =====
FRONTEND_URL=https://www.shupass.jp
BACKEND_TRUSTED_HOSTS=["shupass-backend-production.up.railway.app"]

#PORT=8000

# ===== Sentry（本番は設定推奨） =====
#SENTRY_DSN=
#SENTRY_FASTAPI_DSN=
#BACKEND_SENTRY_DSN=
#SENTRY_ENVIRONMENT=production
#SENTRY_TRACES_SAMPLE_RATE=0.05

# ===== LLM モデル設定（全て Optional） =====
#CLAUDE_SONNET_MODEL=claude-sonnet-4-6
#CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
#GPT_MODEL=gpt-5.4
#GPT_MINI_MODEL=gpt-5.4-mini
#GPT_NANO_MODEL=gpt-5.4-nano
#LOW_COST_REVIEW_MODEL=claude-haiku-4-5-20251001
#GEMINI_MODEL=gemini-3.1-pro-preview
#GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

#MODEL_ES_REVIEW=claude-sonnet
#MODEL_GAKUCHIKA=claude-haiku
#MODEL_GAKUCHIKA_DRAFT=claude-sonnet
#MODEL_MOTIVATION=claude-haiku
#MODEL_MOTIVATION_DRAFT=claude-sonnet
#MODEL_INTERVIEW=claude-haiku
#MODEL_INTERVIEW_PLAN=gpt
#MODEL_INTERVIEW_FEEDBACK=claude-sonnet
#MODEL_SELECTION_SCHEDULE=gpt-mini
#MODEL_COMPANY_INFO=gpt-mini
#MODEL_RAG_QUERY_EXPANSION=gpt-mini
#MODEL_RAG_HYDE=gpt-mini
#MODEL_RAG_CLASSIFY=gpt-nano

#LLM_USAGE_COST_LOG=false
#LLM_TIMEOUT_SECONDS=120
#RAG_TIMEOUT_SECONDS=45

#OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#EMBEDDING_MAX_INPUT_CHARS=8000

#USE_HYBRID_SEARCH=false
#WEB_SEARCH_FAST_MAX_QUERIES=4

# ===== 機能フラグ =====
#MOTIVATION_RAG_GROUNDING=true
#MOTIVATION_MULTIPASS_REFINEMENT=true
#MOTIVATION_SEMANTIC_CONFIRM=false
#MOTIVATION_EMBEDDING_DEDUP=false
#CONTEXTUAL_RETRIEVAL_ENABLED=false
#CONTEXTUAL_RETRIEVAL_DUAL_WRITE=false

#DEBUG=false
#COMPANY_SEARCH_DEBUG=false
#WEB_SEARCH_DEBUG=false
