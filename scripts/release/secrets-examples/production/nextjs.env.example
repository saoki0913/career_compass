# ===== Vercel Production 環境変数 =====
# sync スクリプトが shared.env → nextjs.env の順でマージするため、
# INTERNAL_API_JWT_SECRET / CAREER_PRINCIPAL_HMAC_SECRET / TENANT_KEY_SECRET は
# shared.env で管理し、ここには書かないこと。

# ===== sync メタキー（Vercel CLI 操作に必要） =====
# [Required] Vercel プロジェクトID（Vercel Dashboard → Project Settings → General）
VERCEL_PROJECT_ID=
# [Required] Vercel チームID（Vercel Dashboard → Team Settings）
VERCEL_TEAM_ID=

# ===== 論理環境 =====
# [Required] Vercel 上では production project の Production env に同期する
APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

# ===== データベース =====
# [Required] Supabase PostgreSQL 接続URL（Pooler/6543 推奨）
DATABASE_URL=
#DIRECT_URL=
#DATABASE_POOL_SIZE=

# ===== 認証 (Better Auth + Google OAuth) =====
# [Required] 認証シークレット（32文字以上）
BETTER_AUTH_SECRET=
# [Required] 認証エンドポイントURL
BETTER_AUTH_URL=https://www.shupass.jp
# [Required] 信頼されたオリジン
BETTER_AUTH_TRUSTED_ORIGINS=https://www.shupass.jp,https://shupass.jp
# [Required] Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Stripe 決済 =====
# [Required] 本番 Stripe キー（sk_live_...）
STRIPE_SECRET_KEY=
# [Required] Stripe Webhook シークレット（whsec_...）
STRIPE_WEBHOOK_SECRET=
# [Required] 本番 Price ID
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# [Required] 本番 Customer Portal configuration ID（bpc_...）
STRIPE_PORTAL_CONFIGURATION_ID=

# ===== 暗号化・セキュリティ =====
# [Required] AES-256-GCM 暗号化キー（64桁hex）
ENCRYPTION_KEY=
# [Required] Cron ジョブ認証トークン
CRON_SECRET=

# ===== BFF→FastAPI 接続 =====
# [Required] FastAPI 本番バックエンドURL
FASTAPI_URL=https://shupass-backend-production.up.railway.app
#BACKEND_URL=

# ===== Redis (Upstash) =====
# [Required on deployed AI] Upstash Redis REST URL（日次トークン制限、レートリミット）
# UPSTASH_REDIS_REST_URL は Upstash ダッシュボードの REST API URL を設定
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_NAMESPACE=production

# ===== メール (Resend) =====
#RESEND_API_KEY=
#CONTACT_TO_EMAIL=
#CONTACT_FROM_EMAIL=

# ===== ロゴプロバイダー =====
#LOGO_DEV_TOKEN=
#LOGO_DEV_SECRET_KEY=
#BRANDFETCH_CLIENT_ID=

# ===== Sentry =====
#SENTRY_ORG=
#SENTRY_PROJECT=
#SENTRY_AUTH_TOKEN=
#SENTRY_NEXTJS_DSN=

# ===== 機能フラグ =====
#DISABLE_TOKEN_LIMIT=

# ===== 公開クライアント変数 =====
NEXT_PUBLIC_APP_URL=https://www.shupass.jp
#NEXT_PUBLIC_GA_MEASUREMENT_ID=
#NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
#NEXT_PUBLIC_SENTRY_DSN=

# ===== 特商法表示 =====
#LEGAL_SALES_URL=
#LEGAL_SUPPORT_EMAIL=
#LEGAL_SUPPORT_URL=
#LEGAL_REFUND_POLICY_URL=
#LEGAL_DISCLOSURE_REQUEST_EMAIL=
#LEGAL_DISCLOSURE_REQUEST_NOTICE=
#LEGAL_HEAD_OF_OPERATIONS=
#LEGAL_BUSINESS_NAME=
#LEGAL_REPRESENTATIVE_NAME=
#LEGAL_BUSINESS_ADDRESS=
#LEGAL_PHONE_NUMBER=
