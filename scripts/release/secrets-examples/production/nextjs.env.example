# ===== Vercel Production 環境変数 =====
# sync スクリプトが shared.env → nextjs.env の順でマージするため、
# INTERNAL_API_JWT_SECRET / CAREER_PRINCIPAL_HMAC_SECRET / TENANT_KEY_SECRET は
# shared.env で管理し、ここには書かないこと。

# ===== sync メタキー（Vercel CLI 操作に必要） =====
# [必須] Vercel プロジェクトID（Vercel Dashboard → Project Settings → General） [環境別]
VERCEL_PROJECT_ID=
# [必須] Vercel チームID（Vercel Dashboard → Team Settings） [共通可]
VERCEL_TEAM_ID=

# ===== 論理環境 =====
# [必須] Vercel 上では production project の Production env に同期する [環境別]
APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

# ===== データベース =====
# [必須] Supabase PostgreSQL 接続URL（Pooler/6543 推奨） [環境別]
DATABASE_URL=
# [任意] マイグレーション用 Postgres 直通URL（5432） [環境別]
#DIRECT_URL=
# [任意] コネクションプールサイズ [共通可]
#DATABASE_POOL_SIZE=

# ===== 認証 (Better Auth + Google OAuth) =====
# [必須] 認証シークレット（32文字以上） [環境別]
BETTER_AUTH_SECRET=
# [必須] 認証エンドポイントURL [環境別]
BETTER_AUTH_URL=https://www.shupass.jp
# [必須] 信頼されたオリジン [環境別]
BETTER_AUTH_TRUSTED_ORIGINS=https://www.shupass.jp,https://shupass.jp
# [必須] Google OAuth クライアントID [環境別]
GOOGLE_CLIENT_ID=
# [必須] Google OAuth シークレット [環境別]
GOOGLE_CLIENT_SECRET=

# ===== Stripe 決済 =====
# [必須] 本番 Stripe キー（sk_live_...） [環境別]
STRIPE_SECRET_KEY=
# [必須] Stripe Webhook シークレット（whsec_...） [環境別]
STRIPE_WEBHOOK_SECRET=
# [必須] 本番 Price ID（Stripe Dashboard → Products で作成） [環境別]
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# [必須] 本番 Customer Portal configuration ID（bpc_...） [環境別]
STRIPE_PORTAL_CONFIGURATION_ID=

# ===== 暗号化・セキュリティ =====
# [必須] AES-256-GCM 暗号化キー（64桁hex）。生成: openssl rand -hex 32 [環境別]
ENCRYPTION_KEY=
# [必須] Cron ジョブ認証トークン [環境別]
CRON_SECRET=

# ===== BFF→FastAPI 接続 =====
# [必須] FastAPI 本番バックエンドURL [環境別]
FASTAPI_URL=https://shupass-backend-production.up.railway.app
# [任意] FASTAPI_URL のフォールバック（通常は不要） [環境別]
#BACKEND_URL=

# ===== Redis (Upstash) =====
# [必須] Upstash Redis REST URL（日次トークン制限、レートリミットに使用。staging/production で同一 DB を共有可・namespace で分離） [共有可]
# sync ゲートで必須（require_env_keys）。未設定だと provider 同期が通らない。アプリ単体は起動するがレート制限/トークン制限は無効
UPSTASH_REDIS_REST_URL=
# [必須] Upstash Redis REST トークン（URL と同じ DB・共有時は同一値） [共有可]
UPSTASH_REDIS_REST_TOKEN=
# [任意] Redis 名前空間（未設定なら APP_ENV を使用し staging/production を分離・設定時は APP_ENV と一致必須） [環境別]
UPSTASH_REDIS_NAMESPACE=production

# ===== メール (Resend) =====
# [任意] Resend API キー（お問い合わせフォーム送信に使用） [共通可]
RESEND_API_KEY=
# [任意] お問い合わせ受信先メールアドレス [共通可]
CONTACT_TO_EMAIL=
# [任意] お問い合わせ送信元メールアドレス [共通可]
CONTACT_FROM_EMAIL=

# ===== ロゴプロバイダー =====
# [任意] Logo.dev publishable key（企業アイコンの実ロゴ取得） [共通可]
LOGO_DEV_TOKEN=
# [任意] Logo.dev secret key（企業名から domain を解決） [共通可]
LOGO_DEV_SECRET_KEY=
# [任意] Brandfetch Client ID（Logo.dev fallback） [共通可]
BRANDFETCH_CLIENT_ID=

# ===== Sentry（本番は設定推奨） =====
# [推奨] Sentry 組織スラッグ [共通可]
SENTRY_ORG=
# [推奨] Sentry プロジェクト名 [環境別]
SENTRY_PROJECT=
# [推奨] Sentry Auth トークン（ソースマップアップロード用） [共通可]
SENTRY_AUTH_TOKEN=
# [推奨] Sentry Next.js DSN [環境別]
SENTRY_NEXTJS_DSN=

# ===== 機能フラグ =====
# [任意] true で日次トークン上限チェック全体を無効化 [共通可]
#DISABLE_TOKEN_LIMIT=

# ===== 公開クライアント変数 =====
# [必須] アプリケーション公開URL [環境別]
NEXT_PUBLIC_APP_URL=https://www.shupass.jp
# [任意] Google Analytics 測定ID（本番でも任意 opt-in。使う場合は解除して値を入れる） [環境別]
#NEXT_PUBLIC_GA_MEASUREMENT_ID=
# [任意] Google Search Console 認証タグ（本番でも任意 opt-in。使う場合は解除して値を入れる） [環境別]
#NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# [推奨] Sentry DSN（クライアント側エラー収集） [環境別]
NEXT_PUBLIC_SENTRY_DSN=

# ===== 特商法表示 =====
# 公開情報のため値を事前入力。未設定時は commerce-disclosure.ts のデフォルト値が使用される。
# [任意] [共通可]
LEGAL_SALES_URL=https://www.shupass.jp
LEGAL_SUPPORT_EMAIL=support@shupass.jp
LEGAL_SUPPORT_URL=/contact
LEGAL_REFUND_POLICY_URL=/terms#billing
LEGAL_DISCLOSURE_REQUEST_EMAIL=support@shupass.jp
LEGAL_DISCLOSURE_REQUEST_NOTICE=請求があった場合、購入申込み前に遅滞なく電子メールにて開示いたします。開示をご希望の方は下記メールアドレスまでご連絡ください。
LEGAL_HEAD_OF_OPERATIONS=青木 駿介
LEGAL_BUSINESS_NAME=青木 駿介
LEGAL_REPRESENTATIVE_NAME=青木 駿介
# [任意] 未設定時は LEGAL_DISCLOSURE_REQUEST_NOTICE にフォールバック [共通可]
#LEGAL_BUSINESS_ADDRESS=
#LEGAL_PHONE_NUMBER=
