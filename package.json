{
  "name": "career_compass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:ui:guardrails": "node tools/check-ui-guardrails.mjs",
    "ui:preflight": "node tools/run-ui-preflight.mjs",
    "ui:review:routes": "node tools/resolve-ui-review-routes.mjs",
    "auth:save-playwright-state": "node tools/save-playwright-auth-state.mjs",
    "verify:prepare": "node tools/run-verify-prepare.mjs",
    "verify:change": "node tools/run-verify-change.mjs",
    "verify:manual": "node tools/run-verify-manual.mjs",
    "verify:status": "node tools/run-verify-status.mjs",
    "verify:closeout": "node tools/run-verify-closeout.mjs",
    "demo:record": "bash scripts/marketing/capture-product-demo.sh",
    "demo:render": "node scripts/marketing/render-product-demo.mjs",
    "test:e2e": "playwright test",
    "test:e2e:major": "playwright test e2e/guest-major.spec.ts e2e/user-major.spec.ts",
    "test:e2e:major:guest": "playwright test e2e/guest-major.spec.ts",
    "test:e2e:major:user": "playwright test e2e/user-major.spec.ts",
    "test:e2e:major:live": "playwright test -c playwright.live.config.ts e2e/live-ai-major.spec.ts",
    "test:e2e:release:production": "playwright test e2e/release-production-readonly.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth-boundary.spec.ts",
    "test:e2e:regression": "playwright test e2e/regression-bugs.spec.ts e2e/motivation.spec.ts",
    "test:e2e:functional": "bash scripts/ci/run-e2e-functional.sh --features all",
    "test:e2e:functional:es": "bash scripts/ci/run-e2e-functional.sh --features es-review",
    "test:e2e:functional:gakuchika": "bash scripts/ci/run-e2e-functional.sh --features gakuchika",
    "test:e2e:functional:motivation": "bash scripts/ci/run-e2e-functional.sh --features motivation",
    "test:e2e:functional:interview": "bash scripts/ci/run-e2e-functional.sh --features interview",
    "test:e2e:functional:company-info-search": "bash scripts/ci/run-e2e-functional.sh --features company-info-search",
    "test:e2e:functional:rag-ingest": "bash scripts/ci/run-e2e-functional.sh --features rag-ingest",
    "test:e2e:functional:selection-schedule": "bash scripts/ci/run-e2e-functional.sh --features selection-schedule",
    "test:e2e:functional:local": "bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:company-info-search": "AI_LIVE_LOCAL_FEATURES=company-info-search bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:selection-schedule": "AI_LIVE_LOCAL_FEATURES=selection-schedule bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:rag-ingest": "AI_LIVE_LOCAL_FEATURES=rag-ingest bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:gakuchika": "AI_LIVE_LOCAL_FEATURES=gakuchika bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:motivation": "AI_LIVE_LOCAL_FEATURES=motivation bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:interview": "AI_LIVE_LOCAL_FEATURES=interview bash scripts/dev/run-ai-live-local.sh",
    "test:e2e:functional:local:es": "AI_LIVE_LOCAL_FEATURES=es-review AI_LIVE_LOCAL_SKIP_ES_REVIEW_PLAYWRIGHT=0 bash scripts/dev/run-ai-live-local.sh",
    "test:quality:all": "AI_LIVE_TEST_CATEGORY=quality bash scripts/ci/run-ai-live.sh --feature all",
    "test:static": "npx tsc --noEmit && npm run lint",
    "test:security:light": "bash security/scan/run-lightweight-scan.sh --staged-only --fail-on=critical",
    "test:ui:review": "node tools/run-ui-review.mjs",
    "test:unit": "vitest run",
    "test:agent-pipeline": "node --test scripts/agent-pipeline/sync-pipeline.test.mjs",
    "test:claude-harness": "node --test scripts/claude/claude-harness.test.mjs",
    "test:codex-harness": "node --test scripts/codex/codex-harness.test.mjs",
    "test:verification-harness": "node --test scripts/verification/verification-harness.test.mjs",
    "test:cursor-harness": "node --test scripts/cursor/cursor-harness.test.mjs",
    "test:harness": "npm run test:agent-pipeline && npm run test:claude-harness && npm run test:codex-harness && npm run test:verification-harness && npm run test:cursor-harness",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "agent-pipeline:sync": "node scripts/agent-pipeline/sync-pipeline.mjs",
    "backfill:es-review:qwen-to-low-cost": "node scripts/es-review/backfill-qwen-review-meta.mjs",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:migrate:as-app": "DRIZZLE_MIGRATE_USE_DATABASE_URL=1 dotenv -e .env.local -- drizzle-kit migrate",
    "db:repair:subscription-cancel-column": "dotenv -e .env.local -- node scripts/dev/ensure-cancel-at-period-end-column.mjs",
    "db:migrate:prod": "NODE_OPTIONS=--dns-result-order=ipv4first dotenv -e .env.production -- drizzle-kit migrate",
    "stripe:bootstrap-live": "dotenv -e .env.local -- node scripts/release/stripe-shupass-live-bootstrap.mjs",
    "stripe:inspect": "dotenv -e .env.local -- node scripts/stripe/inspect.mjs",
    "stripe:audit": "dotenv -e .env.local -- node scripts/stripe/audit.mjs",
    "stripe:sync-products": "dotenv -e .env.local -- node scripts/stripe/sync-products.mjs",
    "stripe:sync-webhook": "dotenv -e .env.local -- node scripts/stripe/sync-webhook.mjs",
    "stripe:sync-portal": "dotenv -e .env.local -- node scripts/stripe/sync-portal.mjs",
    "stripe:check-live-readiness": "dotenv -e .env.local -- node scripts/stripe/check-live-readiness.mjs",
    "check:prod-db-drift": "NODE_OPTIONS=--dns-result-order=ipv4first dotenv -e .env.production -- node scripts/dev/check-prod-db-drift.mjs",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "deadcode": "knip --no-progress"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.2.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@remotion/cli": "^4.0.441",
    "@remotion/renderer": "^4.0.441",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "knip": "^5",
    "remotion": "^4.0.441",
    "tailwindcss": "^4",
    "trace-core": "^0.7.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
