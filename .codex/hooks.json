{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-orientation.sh\"",
            "statusMessage": "Loading Career Compass Codex context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|mcp__filesystem__.*|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-dispatcher.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|Read|mcp__filesystem__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/permission-request-guard.sh\"",
            "timeout": 30,
            "statusMessage": "Checking approval request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-bash-output-guard.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-edit-dispatcher.sh\"",
            "timeout": 60,
            "statusMessage": "Recording edit reminders"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/user-prompt-submit-router.sh\"",
            "timeout": 30,
            "statusMessage": "Checking task routing"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-summary.sh\"",
            "timeout": 15,
            "statusMessage": "Summarizing Codex session"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-end-cleanup.sh\"",
            "timeout": 15,
            "statusMessage": "Cleaning up Codex session state"
          }
        ]
      }
    ]
  }
}
